{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "${ALLOWED_HOSTS}",

  "ConnectionStrings": {
    "SqlConnection": "${DB_CONNECTION_STRING}"
  },

  "JwtSettings": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}",
    "DurationInMinutes": 15
  },

  "PaymentSettings": {
    "FrontendUrl": "${FRONTEND_URL}",
    "WebhookUrl": "${WEBHOOK_URL}"
  },

  "Cashfree": {
    "BaseUrl": "${CASHFREE_BASE_URL}",
    "DigiLockerRedirectUrl": "${CASHFREE_DIGILOCKER_REDIRECT}"
  },

  "BillAvenue": {
    "BaseUrl": "${BILLAVENUE_BASE_URL}",
    "MdmUrl": "/billpay/extMdmCntrl/mdmRequestNew/xml",
    "FetchUrl": "/billpay/extBillCntrl/billFetchRequest/xml",
    "PayUrl": "/billpay/extBillPayCntrl/billPayRequest/xml",
    "StatusUrl": "/billpay/transactionStatus/fetchInfo/xml",
    "AccessCode": "${BILLAVENUE_ACCESS_CODE}",
    "WorkingKey": "${BILLAVENUE_WORKING_KEY}",
    "InstituteId": "${BILLAVENUE_INSTITUTE_ID}",
    "AgentId": "${BILLAVENUE_AGENT_ID}",
    "Version": "1.1"
  },

  "Webhook": {
    "CashfreeSecret": "${CASHFREE_WEBHOOK_SECRET}",
    "RazorpaySecret": "${RAZORPAY_WEBHOOK_SECRET}"
  }
}